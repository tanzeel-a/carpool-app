rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User presence - anyone authenticated can read/write their own
    match /userPresence/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == docId;
    }

    // Rides - authenticated users can read all, write their own
    match /rides/{rideId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Match requests - authenticated users can read/write
    match /matchRequests/{requestId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Chats - authenticated users can read/write
    match /chats/{chatId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Matches - authenticated users can read/write
    match /matches/{matchId} {
      allow read, write: if request.auth != null;
    }
  }
}
